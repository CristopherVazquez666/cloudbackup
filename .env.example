PORT=3000
DB_PATH=./data/bovedix.db

JWT_SECRET=change_this_to_a_long_random_secret
SESSION_TTL_HOURS=12
COOKIE_SECURE=false

ADMIN_USER=admin
ADMIN_PASS=change_this_password

# Default cPanel server registered in the control plane
DEFAULT_SERVER_SLUG=neubox-lab
DEFAULT_SERVER_NAME=Neubox Lab
PLUGIN_SHARED_SECRET=change_this_plugin_shared_secret
AUTO_PROVISION_FROM_SSO=true

# Storage backend
STORAGE_HOST=storagebox.hetzner.example
STORAGE_PORT=22
STORAGE_USER=bovedix-sftp
STORAGE_PASS=your_sftp_password
STORAGE_ROOT=/home/bovedix-sftp/storage

# Informational cPanel host field for the default server
CPANEL_HOST=cpanel.neubox.example
